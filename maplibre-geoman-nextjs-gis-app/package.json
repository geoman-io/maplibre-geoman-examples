{
  "name": "maplibre-geoman-nextjs-gis-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "relink": "pnpm --dir ../../maplibre-geoman-pro --filter @geoman-io/maplibre-geoman-pro build && rm -rf node_modules pnpm-lock.yaml .next && pnpm install",
    "dev:fresh": "pnpm relink && pnpm dev"
  },
  "dependencies": {
    "@geoman-io/maplibre-geoman-pro": "0.9.2-alpha.12",
    "@turf/simplify": "^7.3.5",
    "better-auth": "^1.6.22",
    "drizzle-orm": "^0.45.2",
    "maplibre-gl": "^5.24.0",
    "next": "16.2.9",
    "pg": "^8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^26",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^6"
  }
}
