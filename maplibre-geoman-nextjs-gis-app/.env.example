# Copy to .env.local and fill in. .env.local is gitignored.

# Postgres. For local dev use the bundled Docker DB (`pnpm db:up`):
DATABASE_URL=postgres://geoman:geoman@localhost:5435/geoman_gis

# Better Auth. Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me
BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth app — https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
