# Resolve @geoman-io/* (incl. the published Pro build) from Geoman's private
# registry instead of public npm. npm.geoman.io requires a token (anonymous
# reads return 401).
@geoman-io:registry=https://npm.geoman.io/

# The auth token is NOT stored here: pnpm 11 refuses to expand ${ENV} in a
# committed project .npmrc (it could leak a secret to a malicious registry).
# It is injected before install from the GEOMAN_NPM_TOKEN secret (NPM_TOKEN_GEOMAN
# also accepted), the same way geoman-www-v4 does it:
#   • Local: it lives in your user config (`pnpm config get "//npm.geoman.io/:_authToken"`).
#   • Vercel/CI: see `installCommand` in vercel.json — it runs
#     `pnpm config set "//npm.geoman.io/:_authToken" "$GEOMAN_NPM_TOKEN"` before install.
