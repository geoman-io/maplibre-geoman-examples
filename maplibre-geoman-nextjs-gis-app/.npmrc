# Resolve @geoman-io/* (incl. the published Pro build) from Geoman's private
# registry instead of public npm.
@geoman-io:registry=https://npm.geoman.io/

# Auth note — npm.geoman.io requires a token (anonymous reads return 401):
#   • Local: the token lives in your USER config (`pnpm config get
#     "//npm.geoman.io/:_authToken"`), so it is not committed here.
#   • Vercel / CI: do NOT add a `//npm.geoman.io/:_authToken=${VAR}` line to THIS
#     file — pnpm ignores env-var auth that comes from a committed project .npmrc.
#     Instead set the Vercel env var `NPM_RC` (pnpm writes it to a user-level
#     ~/.npmrc, where the token IS honored) to the FULL config with a LITERAL token:
#       @geoman-io:registry=https://npm.geoman.io/
#       //npm.geoman.io/:_authToken=<token>
