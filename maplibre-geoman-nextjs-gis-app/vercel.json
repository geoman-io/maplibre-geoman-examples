{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "build": {
    "env": {
      "ENABLE_EXPERIMENTAL_COREPACK": "1"
    }
  },
  "installCommand": "pnpm config set \"//npm.geoman.io/:_authToken\" \"$NPM_TOKEN_GEOMAN\" && pnpm install --frozen-lockfile",
  "buildCommand": "if [ \"$VERCEL_ENV\" = production ]; then pnpm db:migrate; fi && next build"
}
