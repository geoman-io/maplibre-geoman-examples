{
  "name": "maplibre-geoman-nextjs-solar-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "relink": "pnpm --dir ../../maplibre-geoman-pro --filter @geoman-io/maplibre-geoman-pro build && rm -rf node_modules pnpm-lock.yaml .next && pnpm install",
